# ──────────────────────────────────────────────────────────────────────────
# Cashroom — Local Development Environment Variables (EXAMPLE / TEMPLATE)
#
# HOW TO USE:
#   1. Copy this file to `.env`     ->   cp .env.example .env   (mac/linux)
#                                        copy .env.example .env (windows cmd)
#                                        Copy-Item .env.example .env (powershell)
#   2. Replace every "change_me..." value with a real local value.
#
# RULES:
#   - `.env`          is SECRET and gitignored. NEVER commit it.
#   - `.env.example`  IS committed. It documents which variables exist,
#                     with safe placeholder values — no real secrets.
#
# Docker Compose automatically reads a file literally named `.env` that sits
# in the SAME directory as docker-compose.yml, and substitutes ${VARS}.
# ──────────────────────────────────────────────────────────────────────────

# ---- PostgreSQL ----
POSTGRES_USER=cashroom
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=cashroom_dev
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=change_me_local_only
REDIS_PORT=6379
