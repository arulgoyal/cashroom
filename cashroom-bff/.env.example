# ──────────────────────────────────────────────────────────────────────────
# cashroom-bff — environment variables (EXAMPLE / TEMPLATE)
# Copy to `.env` for host runs:  Copy-Item .env.example .env
# In docker-compose these are supplied by the compose `environment:` block.
# ──────────────────────────────────────────────────────────────────────────

# ---- App ----
PORT=3001
NODE_ENV=development

# ---- Backend target (where the proxy forwards) ----
# Host run: http://localhost:3000 | In compose: http://cashroom-backend:3000
BACKEND_URL=http://localhost:3000

# ---- JWT (MUST match cashroom-backend's JWT_SECRET to verify access tokens) ----
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m

# ---- CORS (the frontend origin allowed to call the BFF) ----
FRONTEND_ORIGIN=http://localhost:5173

# ---- Rate limiting (per IP) ----
THROTTLE_TTL=60      # window length in SECONDS
THROTTLE_LIMIT=100   # max requests per window per IP
