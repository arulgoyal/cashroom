# ──────────────────────────────────────────────────────────────────────────
# cashroom-backend — environment variables (EXAMPLE / TEMPLATE)
#
# Copy to `.env` and fill real local values:  Copy-Item .env.example .env
# `.env` is gitignored; this template is committed.
#
# NOTE: DATABASE_* must match the Postgres credentials created by the ROOT
# docker-compose .env (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB).
# The backend runs on your host and connects to the container via localhost.
# ──────────────────────────────────────────────────────────────────────────

# ---- App ----
PORT=3000
NODE_ENV=development

# ---- Database (must match docker-compose Postgres) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=cashroom
DATABASE_PASSWORD=change_me_local_only
DATABASE_NAME=cashroom_dev

# ---- Auth ----
# bcrypt cost factor: 2^rounds iterations. ~100-250ms per hash is the target.
BCRYPT_ROUNDS=12

# JWT — use long random values in real environments (e.g. `openssl rand -hex 32`).
# Separate secrets for access vs refresh tokens.
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- Redis / BullMQ ----
# Host dev = localhost; in compose the backend service overrides REDIS_HOST=redis.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_local_only

# ---- Email verification (dedicated secret; NOT the access-token secret) ----
EMAIL_VERIFICATION_SECRET=change_me_email_verify_secret
EMAIL_VERIFICATION_EXPIRES_IN=24h

# ---- Observability ----
# SENTRY_DSN empty = Sentry disabled (no-op). Paste a free-tier DSN to enable.
SENTRY_DSN=
LOG_LEVEL=info
# 'json' (machine) or 'pretty' (human). Defaults to json when NODE_ENV=production.
LOG_FORMAT=pretty
